{
	"name": "@torounit/inline-typography-controls",
	"version": "0.4.6",
	"license": "GPL-2.0-or-later",
	"author": "Toro_Unit",
	"scripts": {
		"wp-env": "wp-env",
		"dev": "wp-scripts start",
		"build": "wp-scripts build",
		"format": "wp-scripts format",
		"lint-css": "wp-scripts lint-style",
		"lint-css:fix": "wp-scripts lint-style --fix",
		"lint-js": "wp-scripts lint-js",
		"lint-js:fix": "wp-scripts lint-js --fix",
		"lint-php": "composer lint",
		"lint-php:fix": "composer format",
		"packages-update": "wp-scripts packages-update",
		"prepare": "husky",
		"release": "release-it"
	},
	"lint-staged": {
		"*.{js,json,ts,tsx}": [
			"npm run format"
		],
		"*.{js,ts,tsx}": [
			"npm run lint-js:fix"
		],
		"{*.css,*.scss}": [
			"npm run lint-css:fix"
		],
		"*.php": [
			"composer format",
			"npm run lint-php"
		]
	},
	"dependencies": {
		"@wordpress/block-editor": "^15.21.1",
		"@wordpress/components": "^35.0.1",
		"@wordpress/i18n": "^6.21.1",
		"@wordpress/icons": "^14.0.1",
		"@wordpress/rich-text": "^7.48.1"
	},
	"devDependencies": {
		"@types/wordpress__block-editor": "^11.5.16",
		"@wordpress/env": "^11.8.1",
		"@wordpress/prettier-config": "^4.48.1",
		"@wordpress/scripts": "^32.4.1",
		"husky": "^9.1.6",
		"lint-staged": "^15.2.10",
		"npm-run-all": "^4.1.5",
		"release-it": "^20.2.0"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	},
	"release-it": {
		"hooks": {
			"before:bump": "bash ./bin/bump-version.sh ${version}"
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		}
	}
}
